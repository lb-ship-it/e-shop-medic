---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title={`Portfolio | ${site.brand.name}`} description="Přehled anonymizovaných typů zásahů." robots="noindex,follow" path="/portfolio">
  <main class="shell py-10 md:py-14">
    <section class="panel-strong p-5 md:p-8">
      <p class="eyebrow">Portfolio</p>
      <h1 class="mt-3 text-[1.5rem] font-semibold tracking-tight text-white md:text-[2.1rem]">
        Typy zásahů, které řeším nejčastěji
      </h1>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {site.symptoms.map((item) => (
          <article class="panel p-4 md:p-5">
            <h2 class="text-[1rem] font-semibold text-white md:text-[1.15rem]">{item.title}</h2>
            <p class="mt-2 text-[0.88rem] leading-6 text-white/62 md:text-[0.94rem]">{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
