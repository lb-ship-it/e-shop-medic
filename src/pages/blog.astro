---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title={`Blog | ${site.brand.name}`} description="Krátké poznámky k UX, výkonu a důvěře e‑shopů." robots="noindex,follow" path="/blog">
  <main class="shell py-10 md:py-14">
    <section class="panel-strong p-5 md:p-8">
      <p class="eyebrow">Blog</p>
      <h1 class="mt-3 text-[1.5rem] font-semibold tracking-tight text-white md:text-[2.1rem]">
        Krátké poznámky k UX, výkonu a důvěře e‑shopu
      </h1>
      <p class="mt-4 max-w-2xl text-[0.92rem] leading-7 text-white/64 md:text-[0.98rem]">
        Tahle sekce je připravená pro články, checklisty a krátké rozbory k tomu, proč e‑shopy ztrácejí konverze v detailu produktu, košíku nebo měření.
      </p>
    </section>
  </main>
</BaseLayout>
