---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { site } from "../data/site";

const featuredServices = site.services.slice(0, 3);
const extraServices = site.services.slice(3);
const featuredSymptoms = site.symptoms.slice(0, 2);
const extraSymptoms = site.symptoms.slice(2);
const diagnosticPulsePath = "M0 50 H40 L62 50 L78 16 L92 84 L108 2 L124 98 L140 50 H188 L208 50 L224 18 L238 82 L252 10 L268 50 H320";
const [heroHeadlineLead, ...heroHeadlineTail] = site.brand.heroSeoLead.split(". ");
const heroHeadline = heroHeadlineLead.endsWith(".") ? heroHeadlineLead : `${heroHeadlineLead}.`;
const heroHeadlineSupport = heroHeadlineTail.join(". ").trim();
const heroPlatforms = site.platforms.join(" / ");
---

<BaseLayout title={site.brand.seoTitle} description={site.brand.seoDescription} path="/">
  <main class="relative overflow-hidden pb-12 md:pb-16">
  <main class="relative overflow-hidden pb-12 md:pb-16">
    <div class="absolute inset-0 mesh opacity-55"></div>
    <div class="absolute left-0 top-24 h-60 w-60 rounded-full bg-[color:var(--green)]/10 blur-3xl"></div>
    <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-[color:var(--blue)]/10 blur-3xl"></div>

    <section class="hero-top-offset shell relative">
      <div class="mx-auto max-w-6xl text-center xl:max-w-none">
        <h2 class="mx-auto max-w-[28ch] text-[1.2rem] font-bold uppercase leading-[1.05] tracking-[-0.03em] text-[#b8ff9b] md:max-w-[42ch] md:text-[1.4rem] xl:max-w-none xl:text-[1.5rem] mt-[-2rem]" style="font-size:1.8rem; text-transform:uppercase; margin-top:-2rem;">AUDIT E-SHOPU PRO SHOPTET, WOOCOMMERCE, SHOPIFY A PRESTASHOP</h2>
        <h1 class="hero-claim mx-auto mt-2.5 max-w-6xl">
          {heroHeadline}
        </h1>
        {heroHeadlineSupport && (
          <p class="hero-claim mx-auto mt-1 max-w-6xl">
            {heroHeadlineSupport}
          </p>
        )}
        <p class="mx-auto mt-3 max-w-5xl text-[0.74rem] leading-5 text-white/64 md:text-[0.82rem] md:leading-6 xl:max-w-6xl xl:text-[0.82rem]">
          {site.brand.heroSeoBody}
        </p>
        <p class="mx-auto mt-3.5 max-w-5xl text-[0.7rem] font-medium uppercase tracking-[0.18em] text-[color:var(--green-soft)]/88 md:text-[0.76rem]">
          {heroPlatforms}
        </p>
      </div>

      <div class="mt-7">
        <div class="panel p-4 md:p-6">
          <div class="soft-outline border-b pb-4">
            <p class="eyebrow">Rychlá akce</p>
            <div class="mt-2 flex flex-col gap-2 md:flex-row md:items-center md:justify-between md:gap-6">
              <p class="text-[0.88rem] leading-6 text-white/62 md:text-[0.95rem]">
                Vyber si nejrychlejší placený vstup podle toho, jak moc to hoří. Bez scrollování k detailům, rovnou k rezervaci zásahu.
              </p>
              <div class="flex flex-col gap-1 md:flex-row md:items-center md:gap-3 md:whitespace-nowrap">
                <p class="eyebrow md:mb-0">Platby</p>
                <p class="text-[0.78rem] leading-5 text-white/45">
                  Placené vstupy pokračují přímo přes Stripe.
                </p>
              </div>
            </div>
            <div class="soft-pill hidden shrink-0 rounded-full border px-2.5 py-0.5 text-[0.64rem] md:px-3 md:py-1 md:text-[0.78rem]">
              OmezenĂ˝ rozsah
            </div>
          </div>

          <div class="mt-4 grid gap-2 sm:grid-cols-2 xl:grid-cols-3">
            {site.quickActions.map((action, index) => (
              <a
                href={action.href}
                class:list={[
                  "cta-yellow flex min-h-14 flex-col items-start justify-center rounded-3xl px-4 py-3 text-left md:min-h-16",
                  index === site.quickActions.length - 1 ? "sm:col-span-2 xl:col-span-1" : "",
                ]}
                data-analytics-event="stripe_checkout_click"
                data-analytics-placement="quick_actions"
                data-analytics-offer={action.label}
                data-analytics-target={action.helper}
              >
                <span class="text-[0.76rem] font-bold uppercase tracking-[0.04em]">{action.label}</span>
                <span class="mt-1 text-[0.8rem] font-medium normal-case tracking-normal text-black/72">{action.helper}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-5 panel-strong p-3.5 md:p-6">
        <div class="grid gap-3 md:gap-4">
          <div class="flex flex-row-reverse items-center justify-between gap-3">
            <div class="soft-pill shrink-0 rounded-full border px-2.5 py-0.5 text-[0.64rem] md:px-3 md:py-1 md:text-[0.78rem]">
              Omezený rozsah
            </div>
            <p class="eyebrow">Nezávazná analýza</p>
          </div>

          <div id="audit-zdarma-form" class="soft-outline rounded-[1.2rem] border bg-[color:var(--bg-soft)]/88 p-3 md:p-4.5">
            <div class="mb-2.5">
              <div>
                <p class="text-[0.98rem] font-semibold leading-[1.25] text-white md:text-[1.08rem]">
                  Audit zdarma s čekací dobou 3–5 dní
                </p>
              </div>
              <div class="soft-pill hidden rounded-full border px-3 py-1 text-[0.78rem]">
                Omezený rozsah
              </div>
            </div>

            <form id="free-audit-form" data-recipient={site.contact.email} class="grid gap-2.5 md:grid-cols-2 md:gap-4" novalidate>
              <label class="block">
                <span class="soft-caption mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em]">URL e‑shopu</span>
                <input
                  id="free-audit-url"
                  type="url"
                  name="URL e‑shopu"
                  placeholder="https://vas-eshop.cz"
                  autocomplete="url"
                  aria-required="true"
                  class="form-field"
                />
              </label>
              <label class="block">
                <span class="soft-caption mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em]">Tvůj e-mail</span>
                <input
                  id="free-audit-email"
                  type="email"
                  name="E-mail"
                  placeholder="vas@email.cz"
                  autocomplete="email"
                  inputmode="email"
                  aria-required="true"
                  class="form-field"
                />
              </label>
              <label class="block md:col-span-2">
                <span class="soft-caption mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em]">Poznámka</span>
                <textarea
                  id="free-audit-note"
                  name="Poznámka"
                  rows="2"
                  placeholder="Co teď nejvíc bolí?"
                  class="form-field"
                ></textarea>
              </label>

              <div id="free-audit-message" class="form-alert md:col-span-2" role="alert" aria-live="polite"></div>

              <div class="free-audit-actions flex flex-col gap-2.5 md:col-span-2 md:flex-row md:items-center md:justify-between">
                <p class="soft-note free-audit-note text-[0.72rem] leading-[1.45] md:order-2 md:text-[0.8rem] md:leading-5">
                  Otevře se výchozí poštovní klient. Audit je nezávazný.
                </p>
                <button type="submit" class="cta-green free-audit-submit min-h-10 w-full rounded-[1.15rem] md:order-1 md:min-h-11 md:w-auto md:rounded-2xl">ODESLAT</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="mt-6">
        <div class="space-y-6">
          <div class="max-w-4xl">
            <p class="eyebrow">Diagnostika</p>
            <h2 class="section-title mt-3">Diagnostika e-shopu a UX audit odhalí, kde ztrácíš objednávky</h2>
            <p class="mt-3 max-w-3xl text-[0.9rem] leading-6 text-white/64 md:text-[0.96rem]">
              Ukazuju, kde v e-shopu drhne checkout, kde chybí data a kde se ztrácí důvěra. Tohle je část, kde audit e-shopu a UX audit překlápím do jasné priority zásahu.
            </p>
          </div>

          <div class="panel-strong hero-noise mesh relative overflow-hidden p-4 md:p-5">
            <div class="soft-outline rounded-[1.2rem] border bg-[#091018]/90 p-3 md:p-4">
              <div class="soft-caption flex items-center justify-between text-[0.66rem] uppercase tracking-[0.2em]">
                <span>{site.diagnostic.pulseLabel}</span>
                <span class="text-[color:var(--green)]">{site.diagnostic.statusLabel}</span>
              </div>
              <div class="soft-outline diagnostic-pulse-wrap mt-4 overflow-hidden rounded-[1rem] border bg-[linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.01))] p-3">
                <div class="diagnostic-floating diagnostic-floating-red hidden xl:flex xl:flex-nowrap xl:items-center xl:gap-2.5">
                  <p class="shrink-0 whitespace-nowrap text-[0.58rem] uppercase tracking-[0.18em] text-red-300/72">Urgentní nález</p>
                  <p class="whitespace-nowrap font-medium">Tření v checkoutu</p>
                </div>
                <div class="diagnostic-floating diagnostic-floating-blue hidden xl:flex xl:flex-nowrap xl:items-center xl:gap-2.5">
                  <p class="soft-caption shrink-0 whitespace-nowrap text-[0.58rem] uppercase tracking-[0.18em]">Měření</p>
                  <p class="whitespace-nowrap font-medium">Ve měření chybí 2 události</p>
                </div>
                <svg viewBox="0 0 320 100" class="diagnostic-pulse h-24 w-full md:h-28 lg:h-32 xl:h-36" aria-hidden="true">
                  <path id="diagnostic-pulse-path" d={diagnosticPulsePath} fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="2" />
                  <path d={diagnosticPulsePath} fill="none" stroke="url(#pulseGradient)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" opacity="0.3" />
                  <path d={diagnosticPulsePath} fill="none" stroke="url(#pulseGradient)" stroke-width="14" stroke-linecap="round" stroke-linejoin="round" pathLength="100" class="diagnostic-trace-glow" />
                  <path d={diagnosticPulsePath} fill="none" stroke="url(#pulseGradient)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" pathLength="100" class="diagnostic-trace" />
                  <g class="diagnostic-tracer">
                    <circle r="14" fill="rgba(30,160,255,0.16)"></circle>
                    <circle r="5.5" fill="#f6f7fb"></circle>
                    <circle r="3.5" fill="#18f7a2"></circle>
                    <animateMotion dur="2.2s" repeatCount="indefinite" rotate="auto">
                      <mpath href="#diagnostic-pulse-path"></mpath>
                    </animateMotion>
                  </g>
                  <defs>
                    <linearGradient id="pulseGradient" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="0%" stop-color="#18f7a2"></stop>
                      <stop offset="100%" stop-color="#1ea0ff"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              </div>

              <div class="mt-4 grid gap-2 sm:grid-cols-2">
                {site.diagnostic.cards.map((item) => (
                  <div class:list={["flex min-w-0 items-center gap-1.5 rounded-2xl border px-3 py-2.5", item.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/6" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/6"]}>
                    <p class="truncate whitespace-nowrap text-[0.66rem] text-white/55 md:text-[0.76rem]">{item.label}</p>
                    <p class="shrink-0 whitespace-nowrap text-[0.8rem] font-semibold text-white md:ml-auto md:text-[0.94rem]">{item.score}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div>
            <div class="mb-5 max-w-4xl">
              <p class="eyebrow">Výstupy</p>
              <h2 class="section-title mt-3">Výstupy z auditu e-shopu a návrh dalších kroků</h2>
              <p class="mt-3 max-w-3xl text-[0.9rem] leading-6 text-white/64 md:text-[0.96rem]">
                Výstup obsahuje prioritizaci problémů, důkazy, dopad a akční plán. Přesně tady se technický audit e-shopu, UX audit a SEO optimalizace e-shopu mění na konkrétní rozhodnutí.
              </p>
            </div>

            <div class="grid gap-3 md:gap-4 lg:grid-cols-[0.98fr_1.02fr]">
            <figure class="panel overflow-hidden p-2 md:p-3">
              <button
                type="button"
                class="preview-trigger group block w-full text-left"
                data-preview-src="/archive/critical-funnel.png"
                data-preview-alt="Funnel nákupní cesty s kritickými místy mezi trafficem, landing page, košíkem a checkoutem"
                aria-label="Zvětšit funnel nákupní cesty"
              >
                <span class="eyebrow block px-1 pb-2.5 pt-1">DIAGNOSTIKA</span>
                <div class="preview-frame soft-outline overflow-hidden rounded-[1.2rem] border bg-[color:var(--bg-soft)]">
                  <img
                    src="/archive/critical-funnel.png"
                    alt="Funnel nákupní cesty s kritickými místy mezi trafficem, landing page, košíkem a checkoutem"
                    class="preview-media block h-auto w-full"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </button>
            </figure>

            <figure class="panel overflow-hidden p-2 md:p-3">
              <button
                type="button"
                class="preview-trigger group block w-full text-left"
                data-preview-src="/archive/pdf_outcome.png"
                data-preview-alt="Ukázka PDF výstupu s prioritizací, dopadem, důkazy a akčním plánem"
                aria-label="Zvětšit ukázku PDF výstupu"
              >
                <span class="eyebrow block px-1 pb-2.5 pt-1">VÝSTUPY</span>
                <div class="preview-frame soft-outline overflow-hidden rounded-[1.2rem] border bg-[color:var(--bg-soft)]">
                  <img
                    src="/archive/pdf_outcome.png"
                    alt="Ukázka PDF výstupu s prioritizací, dopadem, důkazy a akčním plánem"
                    class="preview-media block h-auto w-full"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </button>
            </figure>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-anchor-offset symptoms-section shell mt-10 md:mt-12">
      <div class="panel p-4 md:p-6">
        <div class="mb-5 max-w-3xl">
          <p class="eyebrow">Kdy zasáhnout</p>
          <h2 class="section-title mt-3">Kdy kontaktovat e-shop medika</h2>
          <p class="mt-3 text-[0.9rem] leading-6 text-white/64 md:text-[0.96rem]">
            Typické situace, kdy dává smysl audit e-shopu, UX audit nebo rychlý technický zásah. Pokud se poznáš v některém z bodů níže, e-shop už pravděpodobně ztrácí konverze.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {featuredSymptoms.map((symptom) => (
            <article class:list={["rounded-[1.25rem] border p-4 md:p-5", symptom.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/[0.06]" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/[0.06]"]}>
              <div class="flex items-center gap-3">
                <span class:list={["h-3 w-3 rounded-full", symptom.tone === "green" ? "bg-[color:var(--green)]" : "bg-[color:var(--blue)]"]}></span>
                <p class="soft-caption text-[0.72rem] uppercase tracking-[0.24em]">První nález</p>
              </div>
              <h3 class="mt-4 text-[1rem] font-semibold text-white md:text-[1.2rem]">{symptom.title}</h3>
              <p class="mt-2 text-[0.88rem] leading-6 text-white/60 md:text-[0.94rem]">{symptom.description}</p>
            </article>
          ))}
        </div>

        {extraSymptoms.length > 0 && (
          <>
            <details class="mt-5 md:hidden">
              <summary class="pill cursor-pointer list-none">Více symptomů</summary>
              <div class="mt-4 grid gap-4">
                {extraSymptoms.map((symptom) => (
                  <article class:list={["rounded-[1.25rem] border p-4", symptom.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/[0.06]" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/[0.06]"]}>
                    <div class="flex items-center gap-3">
                      <span class:list={["h-3 w-3 rounded-full", symptom.tone === "green" ? "bg-[color:var(--green)]" : "bg-[color:var(--blue)]"]}></span>
                      <p class="soft-caption text-[0.72rem] uppercase tracking-[0.24em]">První nález</p>
                    </div>
                    <h3 class="mt-4 text-[1rem] font-semibold text-white">{symptom.title}</h3>
                    <p class="mt-2 text-[0.88rem] leading-6 text-white/60">{symptom.description}</p>
                  </article>
                ))}
              </div>
            </details>

            <div class="mt-5 hidden md:grid md:grid-cols-2 md:gap-4">
              {extraSymptoms.map((symptom) => (
                <article class:list={["rounded-[1.25rem] border p-5", symptom.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/[0.06]" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/[0.06]"]}>
                  <div class="flex items-center gap-3">
                    <span class:list={["h-3 w-3 rounded-full", symptom.tone === "green" ? "bg-[color:var(--green)]" : "bg-[color:var(--blue)]"]}></span>
                    <p class="soft-caption text-[0.72rem] uppercase tracking-[0.24em]">První nález</p>
                  </div>
                  <h3 class="mt-4 text-[1rem] font-semibold text-white md:text-[1.2rem]">{symptom.title}</h3>
                  <p class="mt-2 text-[0.88rem] leading-6 text-white/60 md:text-[0.94rem]">{symptom.description}</p>
                </article>
              ))}
            </div>
          </>
        )}
      </div>
    </section>

    <section id="sluzby" class="section-anchor-offset shell mt-10 md:mt-12">
      <div class="mb-6">
        <p class="eyebrow">CENÍK</p>
        <h2 class="section-title mt-3">SLUŽBY</h2>
        <p class="mt-3 max-w-3xl text-[0.9rem] leading-6 text-white/64 md:text-[0.96rem]">
          Audit e-shopu, UX audit, SEO optimalizace e-shopu a rychlé zásahy pro Shoptet, WooCommerce, Shopify, PrestaShop i WordPress.
        </p>
      </div>

      <div class="panel-strong p-4 md:p-6">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {featuredServices.map((service) => <ServiceCard {...service} />)}
        </div>

        {extraServices.length > 0 && (
          <>
            <details class="mt-5 md:hidden">
              <summary class="pill cursor-pointer list-none">Další služby</summary>
              <div class="mt-4 grid gap-4">
                {extraServices.map((service) => <ServiceCard {...service} />)}
              </div>
            </details>
            <div class="mt-5 hidden gap-4 md:grid md:grid-cols-2">
              {extraServices.map((service) => <ServiceCard {...service} />)}
            </div>
          </>
        )}
      </div>
    </section>

    <div id="preview-lightbox" class="preview-lightbox" aria-hidden="true">
      <button type="button" class="preview-lightbox-backdrop" data-preview-close aria-label="Zavřít zvětšený náhled"></button>
      <div class="preview-lightbox-panel" role="dialog" aria-modal="true" aria-label="Zvětšený náhled obrázku">
        <button type="button" class="preview-lightbox-close" data-preview-close aria-label="Zavřít náhled">Zavřít</button>
        <img id="preview-lightbox-image" src="" alt="" class="preview-lightbox-image" decoding="async" />
      </div>
    </div>
  </main>
  <script is:inline>
    const freeAuditForm = document.getElementById("free-audit-form");

    if (freeAuditForm instanceof HTMLFormElement) {
      const emitAnalyticsEvent = (name, properties = {}) => {
        window.dispatchEvent(new CustomEvent("eshopmedic:analytics", { detail: { name, properties } }));
      };

      const urlInput = document.getElementById("free-audit-url");
      const emailInput = document.getElementById("free-audit-email");
      const noteInput = document.getElementById("free-audit-note");
      const messageBox = document.getElementById("free-audit-message");

      const supportsFieldHandling =
        urlInput instanceof HTMLInputElement &&
        emailInput instanceof HTMLInputElement &&
        noteInput instanceof HTMLTextAreaElement &&
        messageBox instanceof HTMLDivElement;

      const toggleFieldError = (field, isInvalid) => {
        field.classList.toggle("is-invalid", isInvalid);
      };

      const showMessage = (message) => {
        if (!supportsFieldHandling) return;
        messageBox.textContent = message;
        messageBox.classList.add("is-visible");
      };

      const hideMessage = () => {
        if (!supportsFieldHandling) return;
        messageBox.textContent = "";
        messageBox.classList.remove("is-visible");
      };

      const normalizeUrl = (value) => {
        const trimmed = value.trim();

        if (!trimmed) {
          return "";
        }

        const fixedProtocol = trimmed.replace(/^https?:\/(?!\/)/i, (match) => `${match}/`);
        const withProtocol = /^[a-z][a-z\d+\-.]*:\/\//i.test(fixedProtocol)
          ? fixedProtocol
          : `https://${fixedProtocol.replace(/^\/+/, "")}`;

        try {
          const parsed = new URL(withProtocol);

          if (!parsed.hostname || !parsed.hostname.includes(".")) {
            return null;
          }

          return parsed.toString();
        } catch {
          return null;
        }
      };

      const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim());

      if (supportsFieldHandling) {
        [urlInput, emailInput, noteInput].forEach((field) => {
          field.addEventListener("input", () => {
            toggleFieldError(field, false);
            if (messageBox.classList.contains("is-visible")) {
              hideMessage();
            }
          });
        });
      }

      freeAuditForm.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!supportsFieldHandling) {
          return;
        }

        hideMessage();
        toggleFieldError(urlInput, false);
        toggleFieldError(emailInput, false);

        const normalizedUrl = normalizeUrl(urlInput.value);
        const trimmedEmail = emailInput.value.trim();
        let message = "";

        if (!urlInput.value.trim()) {
          toggleFieldError(urlInput, true);
          message = "Doplň URL e‑shopu, ať vím, na co se podívat.";
        } else if (!normalizedUrl) {
          toggleFieldError(urlInput, true);
          message = "Zadej platnou URL, klidně jen ve tvaru witdesign.cz.";
        }

        if (!trimmedEmail) {
          toggleFieldError(emailInput, true);
          message ||= "Doplň svůj e-mail, ať se ti můžu ozvat.";
        } else if (!isValidEmail(trimmedEmail)) {
          toggleFieldError(emailInput, true);
          message ||= "Zadej platný e-mail ve tvaru jmeno@domena.cz.";
        }

        if (message) {
          showMessage(message);
          (urlInput.classList.contains("is-invalid") ? urlInput : emailInput).focus();
          return;
        }

        const recipient = freeAuditForm.getAttribute("data-recipient");

        if (!recipient) {
          return;
        }

        urlInput.value = normalizedUrl;
        emailInput.value = trimmedEmail;
        const noteValue = noteInput.value.trim();
        const shopHost = (() => {
          try {
            return new URL(normalizedUrl).hostname;
          } catch {
            return "";
          }
        })();

        emitAnalyticsEvent("free_audit_submit", {
          placement: "free_audit_form",
          hasNote: noteValue.length > 0,
          shopHost,
        });

        const subject = "Audit zdarma z witdesign.cz";
        const body = [
          `URL e-shopu: ${normalizedUrl}`,
          `E-mail: ${trimmedEmail}`,
          "",
          "Poznámka:",
          noteInput.value.trim() || "Bez poznámky",
        ].join("\n");

        const mailtoHref = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        window.setTimeout(() => {
          window.location.href = mailtoHref;
        }, 120);
      });
    }

    const previewLightbox = document.getElementById("preview-lightbox");
    const previewLightboxImage = document.getElementById("preview-lightbox-image");
    const previewTriggers = document.querySelectorAll("[data-preview-src]");

    if (previewLightbox instanceof HTMLDivElement && previewLightboxImage instanceof HTMLImageElement && previewTriggers.length > 0) {
      let lastPreviewTrigger = null;

      const openPreview = (trigger) => {
        const src = trigger.getAttribute("data-preview-src");
        const alt = trigger.getAttribute("data-preview-alt") || "";

        if (!src) {
          return;
        }

        lastPreviewTrigger = trigger;
        previewLightboxImage.src = src;
        previewLightboxImage.alt = alt;
        previewLightbox.setAttribute("aria-hidden", "false");
        document.documentElement.style.overflow = "hidden";
      };

      const closePreview = () => {
        previewLightbox.setAttribute("aria-hidden", "true");
        previewLightboxImage.src = "";
        previewLightboxImage.alt = "";
        document.documentElement.style.overflow = "";

        if (lastPreviewTrigger instanceof HTMLElement) {
          lastPreviewTrigger.focus();
        }
      };

      previewTriggers.forEach((trigger) => {
        if (trigger instanceof HTMLElement) {
          trigger.addEventListener("click", () => openPreview(trigger));
        }
      });

      previewLightbox.querySelectorAll("[data-preview-close]").forEach((element) => {
        if (element instanceof HTMLElement) {
          element.addEventListener("click", closePreview);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && previewLightbox.getAttribute("aria-hidden") === "false") {
          closePreview();
        }
      });
    }
  </script>
</BaseLayout>
