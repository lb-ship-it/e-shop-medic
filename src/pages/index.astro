---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { site } from "../data/site";

const featuredServices = site.services.slice(0, 3);
const extraServices = site.services.slice(3);
const featuredSymptoms = site.symptoms.slice(0, 2);
const extraSymptoms = site.symptoms.slice(2);
const diagnosticPulsePath = "M0 50 H40 L62 50 L78 16 L92 84 L108 2 L124 98 L140 50 H188 L208 50 L224 18 L238 82 L252 10 L268 50 H320";
const [heroHeadlineLead, ...heroHeadlineTail] = site.brand.heroLead.split(". ");
const heroHeadline = heroHeadlineLead.endsWith(".") ? heroHeadlineLead : `${heroHeadlineLead}.`;
const heroHeadlineSupport = heroHeadlineTail.join(". ").trim();
---

<BaseLayout path="/">
  <main class="relative overflow-hidden pb-12 md:pb-16">
    <div class="absolute inset-0 mesh opacity-55"></div>
    <div class="absolute left-0 top-24 h-60 w-60 rounded-full bg-[color:var(--green)]/10 blur-3xl"></div>
    <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-[color:var(--blue)]/10 blur-3xl"></div>

    <section class="shell relative pt-5 md:pt-8">
      <div class="mx-auto max-w-6xl text-center xl:max-w-none">
        <p class="mx-auto max-w-[24ch] text-[0.72rem] font-semibold uppercase leading-[1.05] tracking-[-0.03em] text-[#b8ff9b] md:max-w-[32ch] md:text-[0.86rem] xl:max-w-none xl:text-[0.94rem] xl:whitespace-nowrap">
          {site.brand.heroTitle}
        </p>
        <h1 class="mx-auto mt-2.5 max-w-6xl text-[0.72rem] font-bold leading-[1.08] tracking-[-0.03em] text-white md:text-[0.86rem] xl:text-[0.94rem] xl:whitespace-nowrap">
          {heroHeadline}
        </h1>
        {heroHeadlineSupport && (
          <p class="mx-auto mt-0.5 max-w-6xl text-[0.72rem] font-bold leading-[1.08] tracking-[-0.03em] text-white md:text-[0.86rem] xl:text-[0.94rem] xl:whitespace-nowrap">
            {heroHeadlineSupport}
          </p>
        )}
        <p class="mx-auto mt-3 max-w-5xl text-[0.74rem] leading-5 text-white/64 md:text-[0.82rem] md:leading-6 xl:max-w-none xl:text-[0.82rem] xl:whitespace-nowrap">
          {site.brand.heroBody}
        </p>
      </div>

      <div class="mt-7">
        <div class="panel p-4 md:p-6">
          <div class="border-b border-white/8 pb-4">
            <p class="eyebrow">Rychlá akce</p>
            <div class="mt-2 flex flex-col gap-2 md:flex-row md:items-center md:justify-between md:gap-6">
              <p class="text-[0.88rem] leading-6 text-white/62 md:text-[0.95rem]">
                Vyber si nejrychlejší placený vstup podle toho, jak moc to hoří. Bez scrollování k detailům, rovnou k rezervaci zásahu.
              </p>
              <div class="flex flex-col gap-1 md:flex-row md:items-center md:gap-3 md:whitespace-nowrap">
                <p class="eyebrow md:mb-0">Platby</p>
                <p class="text-[0.78rem] leading-5 text-white/45">
                  Placené vstupy pokračují přímo přes Stripe.
                </p>
              </div>
            </div>
            <div class="hidden shrink-0 rounded-full border border-white/10 bg-white/[0.04] px-2.5 py-0.5 text-[0.64rem] text-white/58 md:px-3 md:py-1 md:text-[0.78rem]">
              OmezenĂ˝ rozsah
            </div>
          </div>

          <div class="mt-4 grid gap-2 md:grid-cols-3">
            {site.quickActions.map((action) => (
              <a href={action.href} class="cta-yellow flex min-h-14 flex-col items-start justify-center rounded-3xl px-4 py-3 text-left md:min-h-16" data-analytics-event="stripe_checkout_click" data-analytics-placement="quick_actions" data-analytics-offer={action.label} data-analytics-target={action.helper}>
                <span class="text-[0.76rem] font-bold uppercase tracking-[0.04em]">{action.label}</span>
                <span class="mt-1 text-[0.8rem] font-medium normal-case tracking-normal text-black/72">{action.helper}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-5 panel-strong p-3.5 md:p-6">
        <div class="grid gap-3 md:gap-4">
          <div class="flex flex-row-reverse items-center justify-between gap-3">
            <div class="shrink-0 rounded-full border border-white/10 bg-white/[0.04] px-2.5 py-0.5 text-[0.64rem] text-white/58 md:px-3 md:py-1 md:text-[0.78rem]">
              Omezený rozsah
            </div>
            <p class="eyebrow">Nezávazná analýza</p>
          </div>

          <div id="audit-zdarma-form" class="rounded-[1.2rem] border border-white/8 bg-[color:var(--bg-soft)]/88 p-3 md:p-4.5">
            <div class="mb-2.5">
              <div>
                <p class="text-[0.98rem] font-semibold leading-[1.25] text-white md:text-[1.08rem]">
                  Audit zdarma s čekací dobou 3–5 dní
                </p>
              </div>
              <div class="hidden rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[0.78rem] text-white/58">
                Omezený rozsah
              </div>
            </div>

            <form id="free-audit-form" data-recipient={site.contact.email} class="grid gap-2.5 md:grid-cols-2 md:gap-4" novalidate>
              <label class="block">
                <span class="mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-white/35">URL e‑shopu</span>
                <input
                  id="free-audit-url"
                  type="url"
                  name="URL e‑shopu"
                  placeholder="https://vas-eshop.cz"
                  autocomplete="url"
                  aria-required="true"
                  class="form-field"
                />
              </label>
              <label class="block">
                <span class="mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-white/35">Tvůj e-mail</span>
                <input
                  id="free-audit-email"
                  type="email"
                  name="E-mail"
                  placeholder="vas@email.cz"
                  autocomplete="email"
                  inputmode="email"
                  aria-required="true"
                  class="form-field"
                />
              </label>
              <label class="block md:col-span-2">
                <span class="mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-white/35">Poznámka</span>
                <textarea
                  id="free-audit-note"
                  name="Poznámka"
                  rows="2"
                  placeholder="Co teď nejvíc bolí?"
                  class="form-field"
                ></textarea>
              </label>

              <div id="free-audit-message" class="form-alert md:col-span-2" role="alert" aria-live="polite"></div>

              <div class="free-audit-actions flex flex-col gap-2.5 md:col-span-2 md:flex-row md:items-center md:justify-between">
                <p class="free-audit-note text-[0.72rem] leading-[1.45] text-white/44 md:order-2 md:text-[0.8rem] md:leading-5 md:text-white/48">
                  Otevře se výchozí poštovní klient. Audit je nezávazný.
                </p>
                <button type="submit" class="cta-green free-audit-submit min-h-10 w-full rounded-[1.15rem] md:order-1 md:min-h-11 md:w-auto md:rounded-2xl">ODESLAT</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="mt-6">

        <div class="space-y-6">
          <div class="panel-strong hero-noise mesh relative overflow-hidden p-4 md:p-5">
            <div class="rounded-[1.2rem] border border-white/8 bg-[#091018]/90 p-3 md:p-4">
              <div class="flex items-center justify-between text-[0.66rem] uppercase tracking-[0.2em] text-white/35">
                <span>{site.diagnostic.pulseLabel}</span>
                <span class="text-[color:var(--green)]">{site.diagnostic.statusLabel}</span>
              </div>
              <div class="diagnostic-pulse-wrap mt-4 overflow-hidden rounded-[1rem] border border-white/6 bg-[linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.01))] p-3">
                <div class="diagnostic-floating diagnostic-floating-red hidden lg:flex lg:flex-nowrap lg:items-center lg:gap-2.5">
                  <p class="shrink-0 whitespace-nowrap text-[0.58rem] uppercase tracking-[0.18em] text-red-300/72">Urgentní nález</p>
                  <p class="whitespace-nowrap font-medium">Tření v checkoutu</p>
                </div>
                <div class="diagnostic-floating diagnostic-floating-blue hidden lg:flex lg:flex-nowrap lg:items-center lg:gap-2.5">
                  <p class="shrink-0 whitespace-nowrap text-[0.58rem] uppercase tracking-[0.18em] text-white/35">Měření</p>
                  <p class="whitespace-nowrap font-medium">Ve měření chybí 2 události</p>
                </div>
                <svg viewBox="0 0 320 100" class="diagnostic-pulse h-24 w-full md:h-28 lg:h-32 xl:h-36" aria-hidden="true">
                  <path id="diagnostic-pulse-path" d={diagnosticPulsePath} fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="2" />
                  <path d={diagnosticPulsePath} fill="none" stroke="url(#pulseGradient)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" opacity="0.3" />
                  <path d={diagnosticPulsePath} fill="none" stroke="url(#pulseGradient)" stroke-width="14" stroke-linecap="round" stroke-linejoin="round" pathLength="100" class="diagnostic-trace-glow" />
                  <path d={diagnosticPulsePath} fill="none" stroke="url(#pulseGradient)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" pathLength="100" class="diagnostic-trace" />
                  <g class="diagnostic-tracer">
                    <circle r="14" fill="rgba(30,160,255,0.16)"></circle>
                    <circle r="5.5" fill="#f6f7fb"></circle>
                    <circle r="3.5" fill="#18f7a2"></circle>
                    <animateMotion dur="2.2s" repeatCount="indefinite" rotate="auto">
                      <mpath href="#diagnostic-pulse-path"></mpath>
                    </animateMotion>
                  </g>
                  <defs>
                    <linearGradient id="pulseGradient" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="0%" stop-color="#18f7a2"></stop>
                      <stop offset="100%" stop-color="#1ea0ff"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              </div>

              <div class="mt-4 grid grid-cols-2 gap-2">
                {site.diagnostic.cards.map((item) => (
                  <div class:list={["flex min-w-0 items-center gap-1.5 rounded-2xl border px-3 py-2.5", item.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/6" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/6"]}>
                    <p class="truncate whitespace-nowrap text-[0.66rem] text-white/55 md:text-[0.76rem]">{item.label}</p>
                    <p class="shrink-0 whitespace-nowrap text-[0.8rem] font-semibold text-white md:ml-auto md:text-[0.94rem]">{item.score}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="panel p-4 md:p-6">
            <div class="grid gap-6 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] xl:gap-8">
              <div>
                <p class="eyebrow">Kde a jak zasahuju</p>
                <ul class="mt-4 space-y-3 text-[0.9rem] leading-6 text-white/68 md:text-[0.96rem]">
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[color:var(--green)]"></span>
                    <span>Nejčastěji zasahuju v prostředí <strong class="font-semibold text-white">Shoptet, PrestaShop, WooCommerce, WordPress a Shopify</strong>.</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[color:var(--green)]"></span>
                    <span>Hledám, kudy utíkají objednávky, data nebo důvěra v prvních vteřinách nákupní cesty.</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[color:var(--green)]"></span>
                    <span>Neřeším dekoraci, ale rychlou orientaci a zásah s reálným dopadem na konverzi.</span>
                  </li>
                </ul>
              </div>

              <div class="rounded-[1.2rem] border border-white/8 bg-white/[0.03] p-4 md:p-5">
                <p class="eyebrow">Co čekat po prvním kontaktu</p>
                <ul class="mt-4 space-y-3 text-[0.9rem] leading-6 text-white/68 md:text-[0.96rem]">
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[color:var(--blue)]"></span>
                    <span><strong class="font-semibold text-white">{"První orientace do 24\u00A0hodin"}</strong>, když je problém akutní.</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[color:var(--blue)]"></span>
                    <span><strong class="font-semibold text-white">Zásah držím osobně</strong>, bez přeposílání mezi accounty.</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[color:var(--blue)]"></span>
                    <span>Kontakt a další postup uzavřeme přímo přes <a href={`mailto:${site.contact.email}`} class="text-white underline decoration-white/20 underline-offset-4 transition hover:decoration-white/60">{site.contact.email}</a>.</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="shell mt-10 md:mt-12">
      <div class="panel p-4 md:p-6">
        <div class="mb-5 max-w-3xl">
          <p class="eyebrow">Kdy kontaktovat e‑shop medika</p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {featuredSymptoms.map((symptom) => (
            <article class:list={["rounded-[1.25rem] border p-4 md:p-5", symptom.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/[0.06]" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/[0.06]"]}>
              <div class="flex items-center gap-3">
                <span class:list={["h-3 w-3 rounded-full", symptom.tone === "green" ? "bg-[color:var(--green)]" : "bg-[color:var(--blue)]"]}></span>
                <p class="text-[0.72rem] uppercase tracking-[0.24em] text-white/35">První nález</p>
              </div>
              <h3 class="mt-4 text-[1rem] font-semibold text-white md:text-[1.2rem]">{symptom.title}</h3>
              <p class="mt-2 text-[0.88rem] leading-6 text-white/60 md:text-[0.94rem]">{symptom.description}</p>
            </article>
          ))}
        </div>

        {extraSymptoms.length > 0 && (
          <>
            <details class="mt-5 md:hidden">
              <summary class="pill cursor-pointer list-none">Více symptomů</summary>
              <div class="mt-4 grid gap-4">
                {extraSymptoms.map((symptom) => (
                  <article class:list={["rounded-[1.25rem] border p-4", symptom.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/[0.06]" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/[0.06]"]}>
                    <div class="flex items-center gap-3">
                      <span class:list={["h-3 w-3 rounded-full", symptom.tone === "green" ? "bg-[color:var(--green)]" : "bg-[color:var(--blue)]"]}></span>
                      <p class="text-[0.72rem] uppercase tracking-[0.24em] text-white/35">První nález</p>
                    </div>
                    <h3 class="mt-4 text-[1rem] font-semibold text-white">{symptom.title}</h3>
                    <p class="mt-2 text-[0.88rem] leading-6 text-white/60">{symptom.description}</p>
                  </article>
                ))}
              </div>
            </details>

            <div class="mt-5 hidden md:grid md:grid-cols-2 md:gap-4">
              {extraSymptoms.map((symptom) => (
                <article class:list={["rounded-[1.25rem] border p-5", symptom.tone === "green" ? "border-[color:var(--green)]/18 bg-[color:var(--green)]/[0.06]" : "border-[color:var(--blue)]/18 bg-[color:var(--blue)]/[0.06]"]}>
                  <div class="flex items-center gap-3">
                    <span class:list={["h-3 w-3 rounded-full", symptom.tone === "green" ? "bg-[color:var(--green)]" : "bg-[color:var(--blue)]"]}></span>
                    <p class="text-[0.72rem] uppercase tracking-[0.24em] text-white/35">První nález</p>
                  </div>
                  <h3 class="mt-4 text-[1rem] font-semibold text-white md:text-[1.2rem]">{symptom.title}</h3>
                  <p class="mt-2 text-[0.88rem] leading-6 text-white/60 md:text-[0.94rem]">{symptom.description}</p>
                </article>
              ))}
            </div>
          </>
        )}
      </div>
    </section>

    <section id="sluzby" class="shell mt-10 md:mt-12">
      <div class="mb-6">
        <p class="eyebrow">CENÍK</p>
        <h2 class="section-title mt-3">SLUŽBY</h2>
      </div>

      <div class="panel-strong p-4 md:p-6">
        <div class="grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
          {featuredServices.map((service) => <ServiceCard {...service} />)}
        </div>

        {extraServices.length > 0 && (
          <>
            <details class="mt-5 lg:hidden">
              <summary class="pill cursor-pointer list-none">Další služby</summary>
              <div class="mt-4 grid gap-4">
                {extraServices.map((service) => <ServiceCard {...service} />)}
              </div>
            </details>
            <div class="mt-5 hidden gap-4 lg:grid lg:grid-cols-2">
              {extraServices.map((service) => <ServiceCard {...service} />)}
            </div>
          </>
        )}
      </div>
    </section>

    <section id="proces" class="shell mt-10 grid gap-4 md:mt-12 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="panel-strong p-4 md:p-6">
        <p class="eyebrow">Jak to probíhá</p>
        <div class="mt-4 grid gap-3">
          {site.process.map((item) => (
            <article class="panel p-4 md:p-5">
              <div class="flex items-center gap-3">
                <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[color:var(--green)]/20 bg-[color:var(--green)]/10 text-[0.82rem] font-semibold text-[color:var(--green)]">
                  {item.step}
                </span>
                <h3 class="text-[1rem] font-semibold text-white md:text-[1.2rem]">{item.title}</h3>
              </div>
              <p class="mt-3 text-[0.88rem] leading-6 text-white/60 md:text-[0.94rem]">{item.description}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="panel p-4 md:p-6">
        <p class="eyebrow">Co dostaneš do ruky</p>
        <h2 class="mt-3 text-[1.32rem] font-semibold text-white md:text-[1.85rem]">
          Ne pocit. Konkrétní orientaci.
        </h2>
        <div class="mt-4 space-y-3">
          {site.deliverables.map((item) => (
            <div class="flex items-start gap-3 rounded-[1rem] border border-white/8 bg-white/[0.03] px-3 py-3 md:px-4">
              <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[color:var(--blue)]/12 text-[0.82rem] text-[color:var(--blue)]">
                +
              </span>
              <p class="text-[0.88rem] leading-6 text-white/72 md:text-[0.94rem]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="vstupni-varianty" class="shell mt-10 md:mt-12">
      <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="eyebrow">Vstupní režimy</p>
          <h2 class="section-title mt-3">Dvě cesty podle toho, jak rychle potřebuješ jasno.</h2>
        </div>
        <p class="max-w-xl text-[0.9rem] leading-6 text-white/55 md:text-[0.96rem] md:leading-7">
          Audit zdarma je pomalejší orientační vstup. Express audit je placená priorita pro chvíli, kdy už je čekání dražší než samotný zásah.
        </p>
      </div>

      <div class="grid gap-4 xl:grid-cols-2">
        <article class="panel border-[color:var(--green)]/16 bg-[color:var(--green)]/[0.05] p-4 md:p-5">
          <p class="eyebrow">Varianta A / Free</p>
          <h3 class="mt-3 text-[1.1rem] font-semibold text-white md:text-[1.3rem]">Audit zdarma</h3>
          <p class="mt-2 text-[0.88rem] leading-6 text-white/66 md:text-[0.94rem]">
            Omezený vstupní rozsah pro první orientaci, když nechceš řešit problém naslepo.
          </p>
          <p class="mt-3 text-[0.9rem] font-medium text-[color:var(--green)]">
            Čekací doba 3–5 dní, omezený rozsah.
          </p>
          <div class="mt-4">
            <a href="#audit-zdarma-form" class="cta-green" data-analytics-event="free_audit_focus_click" data-analytics-placement="entry_modes" data-analytics-target="audit_zdarma">ODESLAT</a>
            <p class="mt-2 text-[0.78rem] text-white/48">Zbývají 3 místa v pomalejším režimu.</p>
          </div>
        </article>

        <article class="panel border-[#ffdd00]/28 bg-[#ffdd00]/[0.06] p-4 md:p-5">
          <p class="eyebrow">Varianta B / Paid</p>
          <h3 class="mt-3 text-[1.1rem] font-semibold text-white md:text-[1.3rem]">Express Medic Audit</h3>
          <p class="mt-2 text-[0.88rem] leading-6 text-white/66 md:text-[0.94rem]">
            Placená priorita pro e‑shopy, kde je problém dražší než čekání.
          </p>
          <p class="mt-3 text-[0.9rem] font-medium text-[#ffe67a]">
            {"Garance do 24\u00A0hodin, hloubková analýza + 15min konzultace."}
          </p>
          <div class="mt-4">
            <a href={site.payments.expressAuditHref} class="cta-yellow">{"Express audit 1\u00A0500\u00A0Kč"}</a>
            <p class="mt-2 text-[0.78rem] text-white/48">Platba probíhá bezpečně přes Stripe.</p>
          </div>
        </article>
      </div>
    </section>

    <section id="nahled-vystupu" class="shell mt-10 pb-2 md:mt-12 md:pb-4">
      <div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="eyebrow">Náhled výstupů</p>
          <h2 class="section-title mt-3">Takto přehledně uvidíš rozdíl mezi free a express režimem.</h2>
        </div>
        <p class="max-w-xl text-[0.9rem] leading-6 text-white/55 md:text-[0.96rem] md:leading-7">
          Dole máš dvě vizuální ukázky, aby bylo hned jasné, co dostaneš zdarma a co navíc odemyká Express Audit.
        </p>
      </div>

      <div class="grid gap-4 xl:grid-cols-[1.02fr_0.98fr]">
        <figure class="panel-strong overflow-hidden p-2 md:p-3">
          <div class="overflow-hidden rounded-[1.4rem] border border-white/8 bg-[color:var(--bg-soft)]">
            <img
              src="/archive/audit-compare.svg"
              alt="Srovnání auditu zdarma a Express Auditu"
              class="block h-auto w-full"
              loading="lazy"
              decoding="async"
            />
          </div>
          <figcaption class="px-1.5 pb-1 pt-3 text-[0.84rem] leading-6 text-white/58 md:px-2 md:text-[0.92rem]">
            Rychlé srovnání čekací doby, hloubky analýzy, výstupu a investice bez hledání v textu.
          </figcaption>
        </figure>

        <figure class="panel-strong overflow-hidden p-2 md:p-3">
          <div class="overflow-hidden rounded-[1.4rem] border border-white/8 bg-[color:var(--bg-soft)]">
            <img
              src="/archive/audit-output.svg"
              alt="Ukázka výstupu pro audit zdarma a Express Audit"
              class="block h-auto w-full"
              loading="lazy"
              decoding="async"
            />
          </div>
          <figcaption class="px-1.5 pb-1 pt-3 text-[0.84rem] leading-6 text-white/58 md:px-2 md:text-[0.92rem]">
            Druhý náhled ukazuje rozdíl mezi základním PDF doporučením a express výstupem s akčním plánem a osobním kontaktem.
          </figcaption>
        </figure>
      </div>
    </section>
  </main>
  <script is:inline>
    const freeAuditForm = document.getElementById("free-audit-form");

    if (freeAuditForm instanceof HTMLFormElement) {
      const emitAnalyticsEvent = (name, properties = {}) => {
        window.dispatchEvent(new CustomEvent("eshopmedic:analytics", { detail: { name, properties } }));
      };

      const urlInput = document.getElementById("free-audit-url");
      const emailInput = document.getElementById("free-audit-email");
      const noteInput = document.getElementById("free-audit-note");
      const messageBox = document.getElementById("free-audit-message");

      const supportsFieldHandling =
        urlInput instanceof HTMLInputElement &&
        emailInput instanceof HTMLInputElement &&
        noteInput instanceof HTMLTextAreaElement &&
        messageBox instanceof HTMLDivElement;

      const toggleFieldError = (field, isInvalid) => {
        field.classList.toggle("is-invalid", isInvalid);
      };

      const showMessage = (message) => {
        if (!supportsFieldHandling) return;
        messageBox.textContent = message;
        messageBox.classList.add("is-visible");
      };

      const hideMessage = () => {
        if (!supportsFieldHandling) return;
        messageBox.textContent = "";
        messageBox.classList.remove("is-visible");
      };

      const normalizeUrl = (value) => {
        const trimmed = value.trim();

        if (!trimmed) {
          return "";
        }

        const fixedProtocol = trimmed.replace(/^https?:\/(?!\/)/i, (match) => `${match}/`);
        const withProtocol = /^[a-z][a-z\d+\-.]*:\/\//i.test(fixedProtocol)
          ? fixedProtocol
          : `https://${fixedProtocol.replace(/^\/+/, "")}`;

        try {
          const parsed = new URL(withProtocol);

          if (!parsed.hostname || !parsed.hostname.includes(".")) {
            return null;
          }

          return parsed.toString();
        } catch {
          return null;
        }
      };

      const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim());

      if (supportsFieldHandling) {
        [urlInput, emailInput, noteInput].forEach((field) => {
          field.addEventListener("input", () => {
            toggleFieldError(field, false);
            if (messageBox.classList.contains("is-visible")) {
              hideMessage();
            }
          });
        });
      }

      freeAuditForm.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!supportsFieldHandling) {
          return;
        }

        hideMessage();
        toggleFieldError(urlInput, false);
        toggleFieldError(emailInput, false);

        const normalizedUrl = normalizeUrl(urlInput.value);
        const trimmedEmail = emailInput.value.trim();
        let message = "";

        if (!urlInput.value.trim()) {
          toggleFieldError(urlInput, true);
          message = "Doplň URL e‑shopu, ať vím, na co se podívat.";
        } else if (!normalizedUrl) {
          toggleFieldError(urlInput, true);
          message = "Zadej platnou URL, klidně jen ve tvaru witdesign.cz.";
        }

        if (!trimmedEmail) {
          toggleFieldError(emailInput, true);
          message ||= "Doplň svůj e-mail, ať se ti můžu ozvat.";
        } else if (!isValidEmail(trimmedEmail)) {
          toggleFieldError(emailInput, true);
          message ||= "Zadej platný e-mail ve tvaru jmeno@domena.cz.";
        }

        if (message) {
          showMessage(message);
          (urlInput.classList.contains("is-invalid") ? urlInput : emailInput).focus();
          return;
        }

        const recipient = freeAuditForm.getAttribute("data-recipient");

        if (!recipient) {
          return;
        }

        urlInput.value = normalizedUrl;
        emailInput.value = trimmedEmail;
        const noteValue = noteInput.value.trim();
        const shopHost = (() => {
          try {
            return new URL(normalizedUrl).hostname;
          } catch {
            return "";
          }
        })();

        emitAnalyticsEvent("free_audit_submit", {
          placement: "free_audit_form",
          hasNote: noteValue.length > 0,
          shopHost,
        });

        const subject = "Audit zdarma z witdesign.cz";
        const body = [
          `URL e-shopu: ${normalizedUrl}`,
          `E-mail: ${trimmedEmail}`,
          "",
          "Poznámka:",
          noteInput.value.trim() || "Bez poznámky",
        ].join("\n");

        const mailtoHref = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        window.setTimeout(() => {
          window.location.href = mailtoHref;
        }, 120);
      });
    }
  </script>
</BaseLayout>
