---
import type { ServiceIcon } from "../data/site";

interface Props {
  title: string;
  price: string;
  description: string;
  icon: ServiceIcon;
  ctaLabel?: string;
  ctaHref?: string;
  note?: string;
}

const { title, price, description, icon, ctaLabel, ctaHref, note } = Astro.props;

function getIconPath(iconName: ServiceIcon) {
  switch (iconName) {
    case "audit":
      return "M4 12h8 M4 17h10 M4 7h12 M18 14a3 3 0 1 0 0 6a3 3 0 0 0 0-6Zm2.5 5.5 2 2";
    case "fix":
      return "M20 7.5a4.5 4.5 0 0 1-6.3 4.14L7.6 17.7a2 2 0 1 1-2.82-2.82l6.07-6.08A4.5 4.5 0 0 1 16.5 3l-2.2 2.2 4.5 4.3Z";
    case "seo":
      return "M4 16 10 10l4 4 6-8 M20 8v5h-5";
    case "consulting":
      return "M5 7a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v5a3 3 0 0 1-3 3H9l-4 4v-4a3 3 0 0 1-3-3V7Z M9 10h6";
    case "restart":
      return "M21 12a9 9 0 1 1-2.64-6.36 M21 3v6h-6";
  }
}

const iconPath = getIconPath(icon);
---

<article class="panel flex h-full flex-col p-4 md:p-5">
  <div class="flex items-start justify-between gap-3">
    <div class="glow-green flex h-10 w-10 items-center justify-center rounded-2xl bg-[color:var(--green)]/10 text-[color:var(--green)] md:h-11 md:w-11">
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {iconPath.split(" M").map((segment, index) => (
          <path d={`${index === 0 ? "" : "M"}${segment}`} />
        ))}
      </svg>
    </div>
    <span class="soft-pill rounded-full border px-2.5 py-1 text-[0.72rem] md:text-[0.8rem]">
      {price}
    </span>
  </div>

  <h3 class="mt-4 text-[1rem] font-semibold text-white md:text-[1.2rem]">{title}</h3>
  <p class="mt-2 text-[0.86rem] leading-6 text-white/60 md:text-[0.92rem]">{description}</p>

  {
    ctaLabel && ctaHref ? (
      <div class="mt-auto pt-4">
        <a href={ctaHref} class="cta-yellow w-full" title={ctaLabel} data-analytics-event="stripe_checkout_click" data-analytics-placement="services_grid" data-analytics-offer={title} data-analytics-target={ctaLabel}>
          {ctaLabel}
        </a>
        {note ? <p class="soft-note mt-2 text-[0.76rem] leading-5 md:text-[0.8rem]">{note}</p> : null}
      </div>
    ) : null
  }
</article>
