---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { site } from "../data/site";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = site.brand.title,
  description = site.brand.description,
  path = "/",
  structuredData,
} = Astro.props;

const canonical = new URL(path, site.brand.siteUrl).toString();
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.brand.siteUrl}/#business`,
  name: site.brand.name,
  alternateName: "Witdesign",
  description: site.brand.description,
  url: site.brand.siteUrl,
  email: site.contact.email,
  image: `${site.brand.siteUrl}/logo-mark.png`,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hlohová 367",
    postalCode: "326 00",
    addressLocality: "Letkov",
    addressRegion: "Plzeňský kraj",
    addressCountry: "CZ",
  },
  areaServed: [
    { "@type": "City", name: "Plzeň" },
    { "@type": "AdministrativeArea", name: "Plzeňský kraj" },
    { "@type": "Country", name: "Česká republika" },
  ],
};

const ldPayload = Array.isArray(structuredData)
  ? [defaultStructuredData, ...structuredData]
  : structuredData
    ? [defaultStructuredData, structuredData]
    : [defaultStructuredData];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site.brand.siteUrl}/logo-mark.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#04070b" />
    <link rel="icon" type="image/png" href="/logo-mark.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(ldPayload)} />
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
    <div id="payment-intake" class="payment-intake fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 bg-black/80" aria-hidden="true">
      <button type="button" class="payment-intake-backdrop absolute inset-0 w-full h-full cursor-default" data-payment-intake-close aria-label="Zavřít formulář před platbou"></button>
      
      <div class="payment-intake-panel relative w-full max-w-xl max-h-[90dvh] overflow-y-auto overflow-x-hidden bg-[#121212] rounded-2xl p-6 sm:p-8 shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="payment-intake-title">
        
        <button type="button" class="payment-intake-close absolute top-4 right-4 z-10 text-[0.8rem] text-gray-400 hover:text-white uppercase font-bold tracking-widest" data-payment-intake-close aria-label="Zavřít formulář">Zavřít</button>
        
        <p class="eyebrow mt-4 text-sm text-gray-400 uppercase tracking-widest">Před platbou</p>
        
        <h1 id="payment-intake-title" class="payment-intake-title mt-2.5 text-[1.18rem] font-semibold tracking-tight text-[#90EE90] whitespace-nowrap md:mt-3 md:text-[1.55rem]">
          Nejdřív potřebuji podklady pro servis e-shopu.
        </h1>
        
        <p class="payment-intake-lead mt-2.5 max-w-2xl text-[0.86rem] text-gray-300 leading-5.5 whitespace-nowrap md:mt-3 md:text-[0.94rem] md:leading-6">
          Vyplň prosím všechna pole. Hned potom tě pustím na Stripe platbu pro vybranou službu.
        </p>

        <form id="payment-intake-form" class="payment-intake-form mt-4 md:mt-5" novalidate>
          <div class="payment-intake-grid">
            <label class="block mb-3">
              <span class="payment-intake-label mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-gray-300">Jméno a příjmení</span>
              <input id="payment-intake-name" name="name" type="text" autocomplete="name" class="form-field w-full bg-[#1A1A1A] text-white border border-gray-700 rounded-lg px-4 py-2 focus:border-[#D4A63A] focus:ring-1 focus:ring-[#D4A63A] outline-none transition-colors" placeholder="Jan Novák" aria-required="true" />
            </label>

            <label class="block mb-3">
              <span class="payment-intake-label mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-gray-300">Telefon</span>
              <input id="payment-intake-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" class="form-field w-full bg-[#1A1A1A] text-white border border-gray-700 rounded-lg px-4 py-2 focus:border-[#D4A63A] focus:ring-1 focus:ring-[#D4A63A] outline-none transition-colors" placeholder="+420 777 000 000" aria-required="true" />
            </label>

            <label class="block mb-3">
              <span class="payment-intake-label mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-gray-300">E-mail</span>
              <input id="payment-intake-email" name="email" type="email" autocomplete="email" inputmode="email" class="form-field w-full bg-[#1A1A1A] text-white border border-gray-700 rounded-lg px-4 py-2 focus:border-[#D4A63A] focus:ring-1 focus:ring-[#D4A63A] outline-none transition-colors" placeholder="jan@firma.cz" aria-required="true" />
            </label>

            <label class="block mb-3">
              <span class="payment-intake-label mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-gray-300">URL e-shopu</span>
              <input id="payment-intake-url" name="url" type="url" autocomplete="url" inputmode="url" class="form-field w-full bg-[#1A1A1A] text-white border border-gray-700 rounded-lg px-4 py-2 focus:border-[#D4A63A] focus:ring-1 focus:ring-[#D4A63A] outline-none transition-colors" placeholder="https://vas-eshop.cz" aria-required="true" />
            </label>

            <label class="block payment-intake-note-field mb-3">
              <span class="payment-intake-label mb-1.5 block text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-gray-300">Poznámka</span>
              <textarea id="payment-intake-note" name="note" rows="4" class="form-field w-full bg-[#1A1A1A] text-white border border-gray-700 rounded-lg px-4 py-2 focus:border-[#D4A63A] focus:ring-1 focus:ring-[#D4A63A] outline-none transition-colors" placeholder="Co přesně potřebuješ vyřešit a proč to hoří právě teď?" aria-required="true"></textarea>
            </label>
          </div>

          <div id="payment-intake-message" class="form-alert mt-3.5 md:mt-4 text-red-500 text-sm hidden" role="alert" aria-live="polite"></div>

          <div class="payment-intake-actions mt-4 md:mt-5">
            <p class="payment-intake-meta text-[0.78rem] leading-5 text-gray-400 md:text-[0.84rem] mb-4">
              Údaje použiju jen k přiřazení platby ke konkrétnímu e-shopu a k rychlému navázání zásahu.
            </p>
            <button type="submit" id="payment-intake-submit" class="cta-yellow payment-intake-submit w-full bg-[#D4A63A] text-black font-bold py-3 px-4 rounded-lg hover:bg-[#b58b2e] transition-colors">Pokračovat na platbu</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      // @ts-nocheck
      import { track } from "@vercel/analytics";

      const analyticsPrefix = "analytics";

      const parseDatasetValue = (value) => {
        if (value === "true") return true;
        if (value === "false") return false;
        if (value === "null") return null;
        if (/^-?\d+(\.\d+)?$/.test(value)) return Number(value);
        return value;
      };

      const getAnalyticsProperties = (element) => {
        const properties = {};

        for (const [key, value] of Object.entries(element.dataset)) {
          if (!key.startsWith(analyticsPrefix) || key === "analyticsEvent" || !value) continue;

          const propertyName = key.slice(analyticsPrefix.length);
          if (!propertyName) continue;

          const normalizedName = propertyName.charAt(0).toLowerCase() + propertyName.slice(1);
          properties[normalizedName] = parseDatasetValue(value);
        }

        return properties;
      };

      const normalizeLabel = (value) => value.trim().replace(/\s+/g, " ").slice(0, 80);

      const inferPlacement = (element) => {
        if (element.dataset.analyticsPlacement) return element.dataset.analyticsPlacement;

        const region = element.closest("header, footer, section, article");
        if (!(region instanceof HTMLElement)) return "site";

        if (region.tagName === "HEADER") return "header";
        if (region.tagName === "FOOTER") return "footer";
        if (region.id) return region.id;

        return "content";
      };

      const paymentIntake = {
        root: document.getElementById("payment-intake"),
        form: document.getElementById("payment-intake-form"),
        name: document.getElementById("payment-intake-name"),
        phone: document.getElementById("payment-intake-phone"),
        email: document.getElementById("payment-intake-email"),
        url: document.getElementById("payment-intake-url"),
        note: document.getElementById("payment-intake-note"),
        message: document.getElementById("payment-intake-message"),
        submit: document.getElementById("payment-intake-submit"),
      };

      const paymentIntakeStorageKey = "eshopmedic-payment-intake";
      const paymentIntakeState = {
        paymentUrl: "",
        offer: "",
        placement: "",
        lastTrigger: null,
      };

      const normalizePaymentName = (value) => {
        const normalized = value.trim().replace(/\s+/g, " ");
        return normalized.length >= 3 ? normalized : null;
      };

      const normalizePaymentPhone = (value) => {
        const normalized = value.trim().replace(/\s+/g, " ");
        const digits = normalized.replace(/[^\d]/g, "");
        return digits.length >= 9 ? normalized : null;
      };

      const normalizePaymentEmail = (value) => {
        const normalized = value.trim().toLowerCase();
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(normalized) ? normalized : null;
      };

      const normalizePaymentUrl = (value) => {
        const trimmed = value.trim();

        if (!trimmed) {
          return null;
        }

        const fixedProtocol = trimmed.replace(/^https?:\/(?!\/)/i, (match) => `${match}/`);
        const withProtocol = /^[a-z][a-z\d+\-.]*:\/\//i.test(fixedProtocol)
          ? fixedProtocol
          : `https://${fixedProtocol.replace(/^\/+/, "")}`;

        try {
          const parsed = new URL(withProtocol);

          if (!parsed.hostname || !parsed.hostname.includes(".")) {
            return null;
          }

          return parsed.toString();
        } catch {
          return null;
        }
      };

      const normalizePaymentNote = (value) => {
        const normalized = value.trim().replace(/\s+/g, " ");
        return normalized.length >= 3 ? normalized : null;
      };

      const readPaymentIntakeDraft = () => {
        try {
          const rawValue = window.sessionStorage.getItem(paymentIntakeStorageKey);
          if (!rawValue) return null;

          const parsed = JSON.parse(rawValue);
          if (!parsed || typeof parsed !== "object") return null;

          return parsed;
        } catch {
          return null;
        }
      };

      const writePaymentIntakeDraft = (draft) => {
        try {
          window.sessionStorage.setItem(paymentIntakeStorageKey, JSON.stringify(draft));
        } catch {
          return;
        }
      };

      const appendPrefilledEmail = (paymentUrl, email) => {
        try {
          const url = new URL(paymentUrl);
          url.searchParams.set("prefilled_email", email);
          return url.toString();
        } catch {
          return paymentUrl;
        }
      };

      const openFallbackMailto = (mailtoHref) => {
        const fallbackLink = document.createElement("a");
        fallbackLink.href = mailtoHref;
        fallbackLink.style.display = "none";
        document.body.appendChild(fallbackLink);
        fallbackLink.click();
        fallbackLink.remove();
      };

      if (
        paymentIntake.root instanceof HTMLDivElement &&
        paymentIntake.form instanceof HTMLFormElement &&
        paymentIntake.name instanceof HTMLInputElement &&
        paymentIntake.phone instanceof HTMLInputElement &&
        paymentIntake.email instanceof HTMLInputElement &&
        paymentIntake.url instanceof HTMLInputElement &&
        paymentIntake.note instanceof HTMLTextAreaElement &&
        paymentIntake.message instanceof HTMLDivElement &&
        paymentIntake.submit instanceof HTMLButtonElement
      ) {
        const paymentFields = [
          paymentIntake.name,
          paymentIntake.phone,
          paymentIntake.email,
          paymentIntake.url,
          paymentIntake.note,
        ];

        const fillPaymentIntakeDraft = () => {
          const draft = readPaymentIntakeDraft();
          if (!draft) return;

          paymentIntake.name.value = typeof draft.name === "string" ? draft.name : "";
          paymentIntake.phone.value = typeof draft.phone === "string" ? draft.phone : "";
          paymentIntake.email.value = typeof draft.email === "string" ? draft.email : "";
          paymentIntake.url.value = typeof draft.url === "string" ? draft.url : "";
          paymentIntake.note.value = typeof draft.note === "string" ? draft.note : "";
        };

        const persistPaymentIntakeDraft = () => {
          writePaymentIntakeDraft({
            name: paymentIntake.name.value.trim(),
            phone: paymentIntake.phone.value.trim(),
            email: paymentIntake.email.value.trim(),
            url: paymentIntake.url.value.trim(),
            note: paymentIntake.note.value.trim(),
          });
        };

        const togglePaymentFieldError = (field, isInvalid) => {
          field.classList.toggle("border-red-500", isInvalid);
        };

        const showPaymentMessage = (message) => {
          paymentIntake.message.textContent = message;
          paymentIntake.message.classList.remove("hidden");
        };

        const hidePaymentMessage = () => {
          paymentIntake.message.textContent = "";
          paymentIntake.message.classList.add("hidden");
        };

        const closePaymentIntake = () => {
          paymentIntake.root.setAttribute("aria-hidden", "true");
          document.documentElement.style.overflow = "";
          hidePaymentMessage();

          paymentFields.forEach((field) => togglePaymentFieldError(field, false));

          if (paymentIntakeState.lastTrigger instanceof HTMLElement) {
            paymentIntakeState.lastTrigger.focus();
          }
        };

        const openPaymentIntake = (anchor) => {
          paymentIntakeState.paymentUrl = anchor.href;
          paymentIntakeState.offer =
            anchor.dataset.analyticsOffer || normalizeLabel(anchor.textContent || "") || "Stripe platba";
          paymentIntakeState.placement = inferPlacement(anchor);
          paymentIntakeState.lastTrigger = anchor;

          fillPaymentIntakeDraft();
          hidePaymentMessage();
          paymentFields.forEach((field) => togglePaymentFieldError(field, false));

          paymentIntake.root.setAttribute("aria-hidden", "false");
          document.documentElement.style.overflow = "hidden";
          window.setTimeout(() => paymentIntake.name.focus(), 40);
        };

        paymentFields.forEach((field) => {
          field.addEventListener("input", () => {
            togglePaymentFieldError(field, false);
            if (!paymentIntake.message.classList.contains("hidden")) {
              hidePaymentMessage();
            }
            persistPaymentIntakeDraft();
          });
        });

        paymentIntake.form.addEventListener("submit", async (event) => {
          event.preventDefault();

          hidePaymentMessage();
          paymentFields.forEach((field) => togglePaymentFieldError(field, false));

          if (!paymentIntakeState.paymentUrl.includes("buy.stripe.com")) {
            showPaymentMessage("Platební odkaz se nepodařilo připravit. Zkus to prosím znovu.");
            return;
          }

          const normalizedName = normalizePaymentName(paymentIntake.name.value);
          const normalizedPhone = normalizePaymentPhone(paymentIntake.phone.value);
          const normalizedEmail = normalizePaymentEmail(paymentIntake.email.value);
          const normalizedUrl = normalizePaymentUrl(paymentIntake.url.value);
          const normalizedNote = normalizePaymentNote(paymentIntake.note.value);

          let invalidField = null;
          let message = "";

          if (!normalizedName) {
            invalidField = paymentIntake.name;
            message = "Doplň prosím jméno a příjmení.";
          } else if (!normalizedPhone) {
            invalidField = paymentIntake.phone;
            message = "Doplň prosím platné telefonní číslo.";
          } else if (!normalizedEmail) {
            invalidField = paymentIntake.email;
            message = "Doplň prosím platný e-mail.";
          } else if (!normalizedUrl) {
            invalidField = paymentIntake.url;
            message = "Doplň prosím platnou URL adresu e-shopu.";
          } else if (!normalizedNote) {
            invalidField = paymentIntake.note;
            message = "Doplň prosím stručnou poznámku k problému.";
          }

          if (invalidField instanceof HTMLElement) {
            togglePaymentFieldError(invalidField, true);
            showPaymentMessage(message);
            invalidField.focus();
            return;
          }

          persistPaymentIntakeDraft();

          const originalSubmitLabel = paymentIntake.submit.textContent;
          paymentIntake.submit.disabled = true;
          paymentIntake.submit.textContent = "Odesílám...";

          try {
            const response = await fetch("/api/payment-intake", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                name: normalizedName,
                phone: normalizedPhone,
                email: normalizedEmail,
                url: normalizedUrl,
                note: normalizedNote,
                offer: paymentIntakeState.offer,
                placement: paymentIntakeState.placement,
                paymentUrl: paymentIntakeState.paymentUrl,
              }),
            });

            const payload = await response.json().catch(() => null);

            if (!response.ok || !payload?.ok) {
              throw new Error(
                payload && typeof payload.error === "string"
                  ? payload.error
                  : "Formulář před platbou se nepodařilo odeslat.",
              );
            }

            try {
              const host = new URL(normalizedUrl).hostname;
              track("payment_intake_submit", {
                offer: paymentIntakeState.offer,
                placement: paymentIntakeState.placement,
                shopHost: host,
                fallback: Boolean(payload.fallbackMailto),
              });
            } catch {
              track("payment_intake_submit", {
                offer: paymentIntakeState.offer,
                placement: paymentIntakeState.placement,
                fallback: Boolean(payload.fallbackMailto),
              });
            }

            closePaymentIntake();

            if (typeof payload.fallbackMailto === "string" && payload.fallbackMailto) {
              openFallbackMailto(payload.fallbackMailto);
              window.setTimeout(() => {
                window.location.href = appendPrefilledEmail(paymentIntakeState.paymentUrl, normalizedEmail);
              }, 240);
              return;
            }

            window.location.href = appendPrefilledEmail(paymentIntakeState.paymentUrl, normalizedEmail);
          } catch (error) {
            const message =
              error instanceof Error ? error.message : "Formulář před platbou se nepodařilo odeslat.";

            showPaymentMessage(message);
          } finally {
            paymentIntake.submit.disabled = false;
            paymentIntake.submit.textContent = originalSubmitLabel || "Pokračovat na platbu";
          }
        });

        paymentIntake.root.querySelectorAll("[data-payment-intake-close]").forEach((element) => {
          if (element instanceof HTMLElement) {
            element.addEventListener("click", closePaymentIntake);
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && paymentIntake.root.getAttribute("aria-hidden") === "false") {
            closePaymentIntake();
          }
        });

        document.addEventListener("click", (event) => {
          if (event.defaultPrevented) return;

          if (
            event instanceof MouseEvent &&
            (event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey)
          ) {
            return;
          }

          const anchor = event.target instanceof Element ? event.target.closest("a[href]") : null;
          if (!(anchor instanceof HTMLAnchorElement)) return;
          if (anchor.dataset.skipPaymentIntake === "true") return;
          if (!anchor.href.includes("buy.stripe.com")) return;

          event.preventDefault();
          openPaymentIntake(anchor);
        });
      }

      document.addEventListener("click", (event) => {
        const element = event.target instanceof Element ? event.target : null;
        if (!element) return;

        const target = element.closest("[data-analytics-event]");
        if (!(target instanceof HTMLElement)) return;

        const eventName = target.dataset.analyticsEvent;
        if (!eventName) return;

        const properties = getAnalyticsProperties(target);
        if (!("placement" in properties)) properties.placement = inferPlacement(target);

        const label = normalizeLabel(target.textContent || "");
        if (label && !("label" in properties)) properties.label = label;

        track(eventName, properties);
      });

      document.addEventListener("click", (event) => {
        const anchor = event.target instanceof Element ? event.target.closest("a[href]") : null;
        if (!(anchor instanceof HTMLAnchorElement) || anchor.dataset.analyticsEvent) return;

        const href = anchor.getAttribute("href") || "";
        const label = normalizeLabel(anchor.textContent || "");
        const properties = {
          placement: inferPlacement(anchor),
          label,
        };

        if (href.startsWith("mailto:")) {
          track("contact_email_click", { ...properties, target: "direct_email" });
        } else if (href.includes("buy.stripe.com")) {
          track("stripe_checkout_click", { ...properties, target: "stripe_link" });
        }
      });

      window.addEventListener("eshopmedic:analytics", (event) => {
        if (!(event instanceof CustomEvent)) return;

        const detail = event.detail;
        if (!detail || typeof detail.name !== "string") return;

        const properties =
          detail.properties && typeof detail.properties === "object" ? detail.properties : undefined;

        track(detail.name, properties);
      });
    </script>
  </body>
</html>
