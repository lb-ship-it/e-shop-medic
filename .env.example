# Stripe secret key from the Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Price ID for the featured product in Checkout
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# Optional explicit site URL for local/prod redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend API key for lead notifications from the audit form
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Verified sender address in Resend, e.g. leads@witdesign.cz
LEAD_FROM_EMAIL=leads@example.com

# Optional explicit recipient for lead notifications
LEAD_TO_EMAIL=lblecha@witdesign.cz
